{
  "extends": "@tsconfig/svelte/tsconfig.json",

  "include": ["src/**/*"],
  "exclude": ["node_modules/*"],
  "compilerOptions": {
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "src": ["src/*"]
    },
    "alwaysStrict": true,
    "noImplicitAny": true,
    "typeRoots": ["./node_modules/@types", "./src"]
  }
}